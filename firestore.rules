rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // helper function to check if user is admin or pedagang
    function isAdminOrPedagang() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'pedagang'];
    }

    // users collection – owner can read/write, admin can read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }
    
    // kantin collection – all can read, admin can write, authenticated users can update rating/totalUlasan
    match /kantin/{kantinId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if request.auth != null && (isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'totalUlasan']));
    }
    
    // menu collection – all can read, admin & pedagang can write
    match /menu/{menuId} {
      allow read: if true;
      allow write: if isAdminOrPedagang();
    }
    
    // pesanan collection – user can read/create/write own order; admin/pedagang can read/write
    match /pesanan/{orderId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || isAdminOrPedagang());
      allow update, delete: if request.auth != null && (resource.data.uid == request.auth.uid || isAdminOrPedagang());
    }

    // notifikasi collection – authenticated users can read/write
    match /notifikasi/{notifId} {
      allow read, write: if request.auth != null;
    }

    // favorites collection – authenticated users can read/write
    match /favorites/{favId} {
      allow read, write: if request.auth != null;
    }

    // ulasan collection – all can read, authenticated can write
    match /ulasan/{ulasanId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // vouchers collection – authenticated users can read/write
    match /vouchers/{voucherId} {
      allow read, write: if request.auth != null;
    }

    // default deny for any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
